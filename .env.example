# Example environment variables for Mutuini Virtual Care Portal
# Do not place real secrets in this file.
# Use this file as a template and create a local .env with real values.
# SHA/SMS/WhatsApp variables are placeholders for later integration.

DATABASE_URL=
NEXTAUTH_SECRET=
NEXTAUTH_URL=
SHA_BASE_URL=
SHA_CLIENT_ID=
SHA_CLIENT_SECRET=
SHA_FACILITY_CODE=
SHA_ENVIRONMENT=development
SMS_API_KEY=
WHATSAPP_API_TOKEN=
EMAIL_SERVER=
EMAIL_FROM=
